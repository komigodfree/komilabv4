/*
  # Anti-clickjacking
  X-Frame-Options: DENY

  # Anti-sniffing MIME
  X-Content-Type-Options: nosniff

  # XSS Protection navigateurs anciens
  X-XSS-Protection: 1; mode=block

  # HTTPS forcé 1 an
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Referrer minimal
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions navigateur — désactive ce dont on n'a pas besoin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()

  # Content Security Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.rss2json.com https://connect.mailerlite.com; frame-ancestors 'none';

